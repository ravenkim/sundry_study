# 로컬에서만 `.env` / `.env.development` / `.env.production` 으로 복사 후 사용합니다. (복사본은 git에 넣지 않음)
#
# 서비스 유형 예: S 일반 / D 개발연동 / P 운영
REACT_APP_SERVICE_VERSION=0.0.1
REACT_APP_SERVICE_TYPE=S
REACT_APP_API_HOST=http://127.0.0.1:8000
REACT_APP_IMAGE_ACCEPT="png,jpg,jpeg,gif"
REACT_APP_FILE_ACCEPT="hwp,doc,pdf,ppt,pptx,txt,docx,xls,xlsx"
